{
    "name": "stab-dreissene",
    "description": "STAB-DREISSENE pipeline: parse -> clean -> resample -> transform -> aggregate -> exportcsv (valvométrie moules + environnement BME680)",
    "dataset": "STAB-DREISSENE",
    "steps": [
        {
            "treatment": "parse",
            "name": "parse",
            "input": "00_raw",
            "output": "10_parsed",
            "params": {
                "domains": {
                    "bio_signal": {
                        "prefix": "m",
                        "dtype": "int"
                    },
                    "environment": {
                        "columns": ["bme680_temp", "bme680_pression", "bme680_humidity"],
                        "dtype": "float"
                    }
                }
            }
        },
        {
            "treatment": "clean",
            "name": "clean",
            "input": "10_parsed",
            "output": "20_clean"
        },
        {
            "treatment": "resample",
            "name": "resample",
            "input": "20_clean",
            "output": "25_resampled",
            "params": {
                "max_gap_fill_s": 20
            }
        },
        {
            "treatment": "transform",
            "name": "transform",
            "input": "25_resampled",
            "output": "30_transform"
        },
        {
            "treatment": "aggregate",
            "name": "aggregate",
            "input": "30_transform",
            "output": "40_aggregated",
            "params": {
                "windows": ["10s", "60s", "5min"]
            }
        },
        {
            "treatment": "exportcsv",
            "name": "exportcsv",
            "input": "40_aggregated",
            "output": "61_exportcsv",
            "params": {
                "aggregation": "10s",
                "domain": "bio_signal",
                "tz": "Europe/Paris",
                "columns": {
                    "m0__raw__mean": "m0",
                    "m1__raw__mean": "m1",
                    "m2__raw__mean": "m2",
                    "m3__raw__mean": "m3",
                    "m4__raw__mean": "m4",
                    "m5__raw__mean": "m5"
                }
            }
        },
        {
            "treatment": "exportparquet",
            "name": "exportparquet",
            "input": "40_aggregated",
            "output": "62_exportparquet",
            "params": {
                "aggregation": "10s",
                "domain": "bio_signal",
                "columns": {
                    "m0__raw__mean": "m0",
                    "m1__raw__mean": "m1",
                    "m2__raw__mean": "m2",
                    "m3__raw__mean": "m3",
                    "m4__raw__mean": "m4",
                    "m5__raw__mean": "m5"
                }
            }
        }
    ]
}
